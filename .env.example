# Required — get your key at https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional — defaults to minimax/minimax-m2.7
# OPENROUTER_MODEL=minimax/minimax-m2.7

# PromptFoo grading — routes llm-rubric assertions through OpenRouter
# Set these to the same OpenRouter key for PromptFoo evaluation
# OPENAI_API_KEY=sk-or-your-key-here
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
